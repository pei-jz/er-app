{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "J.H ER Editor",
  "version": "0.1.0",
  "identifier": "com.erdiagram.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "J.H ER Editor",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "ER Diagram File",
        "ext": [
          "er"
        ],
        "description": "J.H ER Editor Project File",
        "role": "Editor"
      }
    ]
  }
}